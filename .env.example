# Application version shown in header when set (e.g. 1.0.0 — do not include a "v" prefix)
VITE_APP_VERSION=

# Backend base URL for /health and future API (no trailing slash)
VITE_API_BASE_URL=

# Store profile (optional; defaults are used when unset)
VITE_STORE_NAME=
VITE_STORE_ADDRESS=
VITE_STORE_ACCESS_NOTE=
VITE_STORE_PHONE_DISPLAY=
VITE_STORE_PHONE_E164=
VITE_STORE_PHONE_HOURS=
VITE_STORE_LAT=
VITE_STORE_LNG=
